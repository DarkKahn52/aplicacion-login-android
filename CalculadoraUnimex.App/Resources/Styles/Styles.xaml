<?xml version="1.0" encoding="UTF-8" ?><ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
<Style x:Key="GlassCard" TargetType="Border"><Setter Property="Padding" Value="28"/><Setter Property="BackgroundColor" Value="#B8051937"/><Setter Property="Stroke" Value="#8800E5FF"/><Setter Property="StrokeThickness" Value="1"/><Setter Property="StrokeShape"><Setter.Value><RoundRectangle CornerRadius="28"/></Setter.Value></Setter><Setter Property="Shadow"><Setter.Value><Shadow Brush="#6600E5FF" Radius="22" Opacity="0.7" Offset="0,4"/></Setter.Value></Setter></Style>
<Style x:Key="Title" TargetType="Label"><Setter Property="TextColor" Value="White"/><Setter Property="FontSize" Value="30"/><Setter Property="FontAttributes" Value="Bold"/></Style><Style x:Key="Subtitle" TargetType="Label"><Setter Property="TextColor" Value="#D9ECFF"/><Setter Property="FontSize" Value="15"/></Style>
<Style x:Key="NeonEntry" TargetType="Entry"><Setter Property="TextColor" Value="White"/><Setter Property="PlaceholderColor" Value="#C7DAF5"/><Setter Property="BackgroundColor" Value="#22FFFFFF"/><Setter Property="HeightRequest" Value="54"/><Setter Property="Margin" Value="0,3"/></Style>
<Style x:Key="PrimaryButton" TargetType="Button"><Setter Property="TextColor" Value="White"/><Setter Property="FontAttributes" Value="Bold"/><Setter Property="FontSize" Value="16"/><Setter Property="HeightRequest" Value="54"/><Setter Property="CornerRadius" Value="14"/><Setter Property="Background"><Setter.Value><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#00C8FF"/><GradientStop Color="#005EFF" Offset="1"/></LinearGradientBrush></Setter.Value></Setter></Style>
<Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}"><Setter Property="Background" Value="#3300E5FF"/><Setter Property="BorderColor" Value="#00E5FF"/><Setter Property="BorderWidth" Value="1"/></Style><Style x:Key="DangerButton" TargetType="Button"><Setter Property="TextColor" Value="White"/><Setter Property="BackgroundColor" Value="#C62828"/><Setter Property="CornerRadius" Value="12"/><Setter Property="Padding" Value="16,8"/></Style>
</ResourceDictionary>
