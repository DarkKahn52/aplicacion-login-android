<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage x:Class="CalculadoraUnimex.App.Pages.CarPage" xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" BackgroundColor="{StaticResource Navy900}">
<Grid RowDefinitions="Auto,*"><Border Grid.Row="0" BackgroundColor="#D1020819" Stroke="#00E5FF" StrokeThickness="1" Padding="18"><Grid ColumnDefinitions="Auto,*,Auto"><Image Source="logo.png" HeightRequest="50"/><VerticalStackLayout Grid.Column="1" Margin="12,0"><Label Text="Calculadora UNIMEX" TextColor="White" FontSize="20" FontAttributes="Bold"/><Label x:Name="UserLabel" TextColor="#D9ECFF" FontSize="12"/></VerticalStackLayout><Button Grid.Column="2" Text="Salir" Style="{StaticResource DangerButton}" Clicked="OnLogoutClicked"/></Grid></Border>
<ScrollView Grid.Row="1"><VerticalStackLayout Padding="24" Spacing="22"><Border Style="{StaticResource GlassCard}"><VerticalStackLayout Spacing="16"><Label Text="¡Bienvenido!" Style="{StaticResource Title}" HorizontalTextAlignment="Center"/><Label Text="Gracias por visitarnos. Observa este coche aleatorio como agradecimiento." Style="{StaticResource Subtitle}" HorizontalTextAlignment="Center"/><Border BackgroundColor="#55001435" Stroke="#00E5FF" StrokeThickness="1" StrokeShape="RoundRectangle 22" HeightRequest="280"><Grid><Image x:Name="CarImage" Aspect="AspectFill"/><ActivityIndicator x:Name="Loading" IsRunning="False" IsVisible="False" Color="#00E5FF"/><Label x:Name="MessageLabel" Text="Pulsa el botón para cargar un coche" TextColor="#D9ECFF" HorizontalTextAlignment="Center" VerticalTextAlignment="Center"/></Grid></Border><Button x:Name="ChangeButton" Text="Cambiar coche" Style="{StaticResource PrimaryButton}" Clicked="OnChangeCarClicked"/></VerticalStackLayout></Border></VerticalStackLayout></ScrollView></Grid></ContentPage>
