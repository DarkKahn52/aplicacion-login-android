<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage x:Class="CalculadoraUnimex.App.Pages.RegisterPage" xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" BackgroundColor="{StaticResource Navy900}">
<Grid><Grid.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#05295F"/><GradientStop Color="#0A3D91" Offset="0.55"/><GradientStop Color="#03152F" Offset="1"/></LinearGradientBrush></Grid.Background>
<ScrollView><VerticalStackLayout Padding="28" Spacing="20" VerticalOptions="Center"><Border Style="{StaticResource GlassCard}"><VerticalStackLayout Spacing="16">
<Image Source="logo.png" HeightRequest="105"/><Label Text="Crear cuenta" Style="{StaticResource Title}" HorizontalTextAlignment="Center"/><Label Text="Registra tus datos para acceder" Style="{StaticResource Subtitle}" HorizontalTextAlignment="Center"/>
<Entry x:Name="NameEntry" Placeholder="Nombre completo" Style="{StaticResource NeonEntry}"/><Entry x:Name="EmailEntry" Placeholder="Correo electrónico" Keyboard="Email" Style="{StaticResource NeonEntry}"/><Entry x:Name="PasswordEntry" Placeholder="Contraseña" IsPassword="True" Style="{StaticResource NeonEntry}"/><Entry x:Name="ConfirmEntry" Placeholder="Confirmar contraseña" IsPassword="True" Style="{StaticResource NeonEntry}"/>
<Button x:Name="RegisterButton" Text="Registrarme" Style="{StaticResource PrimaryButton}" Clicked="OnRegisterClicked"/><Button Text="Volver al inicio de sesión" Style="{StaticResource SecondaryButton}" Clicked="OnBackClicked"/><ActivityIndicator x:Name="Loading" IsVisible="False" Color="#00E5FF"/><Label x:Name="MessageLabel" HorizontalTextAlignment="Center" IsVisible="False"/>
</VerticalStackLayout></Border></VerticalStackLayout></ScrollView></Grid></ContentPage>
